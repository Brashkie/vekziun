{
  "name": "@vekziun/napi",
  "version": "0.1.1",
  "description": "Compila y resuelve addons NAPI-RS multiplataforma con un contrato único triple→suffix→package.",
  "license": "Apache-2.0",
  "author": "Brashkie (Hepein Oficial)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Brashkie/vekziun.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./loader": {
      "types": "./dist/napi/loader.d.ts",
      "default": "./dist/napi/loader.js"
    },
    "./build": {
      "types": "./dist/napi/build.d.ts",
      "default": "./dist/napi/build.js"
    },
    "./triples": {
      "types": "./dist/core/triples.d.ts",
      "default": "./dist/core/triples.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "vekziun": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx tests/contract.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
